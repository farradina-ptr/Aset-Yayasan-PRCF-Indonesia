<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Monitoring Aset LPHD — PRCF Indonesia</title>
<meta name="description" content="Data inventaris dan kondisi aset enam lokasi Lembaga Pengelola Hutan Desa (LPHD) dampingan PRCF Indonesia.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --forest:#1d3b2f; --forest-2:#264e3e; --moss:#5a7d52;
  --leaf:#7fa86b; --bark:#5b4636; --clay:#c66b3d; --sun:#d9a441;
  --paper:#f5f2ea; --paper-2:#ece7d9; --ink:#22271f; --muted:#6b7268;
  --line:#d8d2c4; --white:#fffdf8;
  --good:#3f7d4e; --bad:#c0492f; --lost:#8a6d3b; --fix:#b9892a; --na:#9a9488;
  --shadow:0 1px 2px rgba(29,59,47,.06),0 6px 24px rgba(29,59,47,.07);
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'Inter',system-ui,sans-serif;background:var(--paper);color:var(--ink);line-height:1.55;-webkit-font-smoothing:antialiased}
.wrap{max-width:1180px;margin:0 auto;padding:0 22px}
a{color:inherit}

/* ---------- Header ---------- */
header.top{background:var(--forest);color:var(--paper);position:relative;overflow:hidden}
header.top::before{content:"";position:absolute;inset:0;background:
  radial-gradient(900px 400px at 88% -10%,rgba(217,164,65,.16),transparent 60%),
  radial-gradient(700px 500px at -5% 120%,rgba(127,168,107,.18),transparent 60%);pointer-events:none}
.nav{display:flex;align-items:center;justify-content:space-between;padding:18px 0;position:relative;z-index:2}
.brand{display:flex;align-items:center;gap:12px;font-weight:600;letter-spacing:.02em}
.brand .mark{width:34px;height:34px;flex:none}
.brand small{display:block;font-weight:400;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--leaf)}
.nav .gh{font-size:13px;border:1px solid rgba(245,242,234,.3);padding:7px 14px;border-radius:99px;text-decoration:none;transition:.2s}
.nav .gh:hover{background:rgba(245,242,234,.1)}
.hero{padding:34px 0 54px;position:relative;z-index:2}
.eyebrow{font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.22em;text-transform:uppercase;color:var(--sun);margin-bottom:16px}
.hero h1{font-family:'Fraunces',serif;font-weight:600;font-size:clamp(34px,5.5vw,60px);line-height:1.02;letter-spacing:-.01em;max-width:16ch}
.hero p.lede{margin-top:18px;max-width:60ch;font-size:17px;color:rgba(245,242,234,.85)}
.hero .meta{margin-top:22px;display:flex;gap:26px;flex-wrap:wrap;font-size:13px;color:rgba(245,242,234,.7);font-family:'JetBrains Mono',monospace}
.hero .meta b{color:var(--leaf);font-weight:500}

/* ---------- Stat band ---------- */
.statband{background:var(--forest-2);position:relative;z-index:2}
.statgrid{display:grid;grid-template-columns:repeat(6,1fr);gap:1px;background:rgba(245,242,234,.12)}
.stat{background:var(--forest-2);padding:20px 18px;color:var(--paper)}
.stat .n{font-family:'Fraunces',serif;font-size:30px;font-weight:600;line-height:1}
.stat .l{font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:rgba(245,242,234,.6);margin-top:7px}
