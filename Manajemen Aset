<script>
const COND_ORDER=['Baik','Perbaikan','Rusak','Hilang','Belum Tercatat'];
const COND_COLOR={'Baik':'#5a7d52','Perbaikan':'#b9892a','Rusak':'#c0492f','Hilang':'#d9a441','Belum Tercatat':'#9a9488'};
let DB=null, curLoc='Semua', sortK='nama', sortDir=1;

const $=s=>document.querySelector(s);
const esc=s=>(s==null?'':String(s)).replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
const cls=s=>String(s).replace(/\s+/g,'');

fetch('data.json').then(r=>r.json()).then(d=>{DB=d;init();})
  .catch(e=>{$('#tbody').innerHTML='<tr><td colspan="6" class="empty"><h3>Data tidak termuat</h3><p>Pastikan berkas data.json berada di folder yang sama.</p></td></tr>';});

function allItems(){let a=[];for(const k in DB.data)a=a.concat(DB.data[k]);return a;}

function init(){
  const items=allItems();
  // hero meta
  $('#herometa').innerHTML=
    `<div><b>${items.length}</b> aset tercatat</div>`+
    `<div><b>${DB.meta.lokasi.length}</b> lokasi</div>`+
    `<div>Diperbarui <b>${DB.meta.digenerate}</b></div>`;
  // global stats
  const g=tally(items);
  $('#statgrid').innerHTML=[
    ['Total aset',items.length,''],
    ['Kondisi baik',g['Baik']||0,'good'],
    ['Rusak',g['Rusak']||0,'bad'],
    ['Hilang',g['Hilang']||0,'lost'],
    ['Perbaikan',g['Perbaikan']||0,''],
    ['Belum tercatat',g['Belum Tercatat']||0,'']
  ].map(([l,n,c])=>`<div class="stat ${c}"><div class="n ${c?'dot':''}">${n}</div><div class="l">${l}</div></div>`).join('');
  // category filter
  const cats=[...new Set(items.map(i=>i.kelompok))].sort();
  $('#fcat').innerHTML='<option value="">Semua kategori</option>'+cats.map(c=>`<option>${esc(c)}</option>`).join('');
  $('#fcond').innerHTML='<option value="">Semua kondisi</option>'+COND_ORDER.map(c=>`<option>${c}</option>`).join('');
  // location tabs
  const locs=['Semua',...DB.meta.lokasi];
  $('#loctabs').innerHTML=locs.map(l=>{
    const n=l==='Semua'?items.length:DB.data[l].length;
    return `<button class="loctab ${l===curLoc?'active':''}" data-loc="${esc(l)}">${esc(l)}<span class="badge">${n}</span></button>`;
  }).join('');
  // footer
  $('#footloc').innerHTML=DB.meta.lokasi.join(' · ');
  $('#footfine').textContent=`Sumber: ${DB.meta.sumber} · Digenerate ${DB.meta.digenerate} · ${items.length} baris data`;

  // events
  $('#q').addEventListener('input',render);
  $('#fcat').addEventListener('change',render);
  $('#fcond').addEventListener('change',render);
  document.querySelectorAll('thead th').forEach(th=>th.addEventListener('click',()=>{
    const k=th.dataset.k; sortDir=(sortK===k)?-sortDir:1; sortK=k; render();
  }));
  $('#loctabs').addEventListener('click',e=>{
    const b=e.target.closest('.loctab'); if(!b)return;
    curLoc=b.dataset.loc;
    document.querySelectorAll('.loctab').forEach(x=>x.classList.toggle('active',x===b));
    render();
  });
  // sticky shadow
  const obs=new IntersectionObserver(([e])=>$('#controls').classList.toggle('stuck',e.intersectionRatio<1),{threshold:[1]});
  // github link placeholder
  $('#ghlink').href='#';
  render();
}

function tally(items){const t={};items.forEach(i=>{t[i.kondisi_terkini]=(t[i.kondisi_terkini]||0)+1});return t;}

function currentSet(){
  if(curLoc==='Semua')return allItems();
  return DB.data[curLoc]||[];
}

function render(){
  const q=$('#q').value.trim().toLowerCase();
  const fc=$('#fcat').value, fk=$('#fcond').value;
  let set=currentSet().slice();
  if(fc)set=set.filter(i=>i.kelompok===fc);
  if(fk)set=set.filter(i=>i.kondisi_terkini===fk);
  if(q)set=set.filter(i=>(
    (i.nama+' '+i.spesifikasi+' '+i.kode+' '+i.serial+' '+i.pemasok+' '+i.lokasi).toLowerCase().includes(q)
  ));
  set.sort((a,b)=>{
    let x=a[sortK]||'',y=b[sortK]||'';
    if(sortK==='jumlah'){x=+x||0;y=+y||0;return (x-y)*sortDir;}
    return String(x).localeCompare(String(y),'id')*sortDir;
  });
  renderSummary();
  $('#count').textContent=`${set.length} ditampilkan`;
  // table
  if(!set.length){
    $('#tbody').innerHTML=`<tr><td colspan="6" class="empty"><h3>Tidak ada hasil</h3><p>Coba ubah kata kunci atau filter.</p></td></tr>`;
    return;
  }
  $('#tbody').innerHTML=set.map((i,idx)=>{
    const cond=esc(i.kondisi_terkini);
    return `<tr class="main" data-i="${idx}">
      <td><div class="item-name">${esc(i.nama)}</div><div class="item-spec">${esc(i.spesifikasi)}</div></td>
      <td><span class="kode">${esc(i.kode||'—')}</span></td>
      <td><span class="cat-tag">${esc(i.kelompok)}</span></td>
      <td>${esc(i.jumlah)} <span style="color:var(--muted);font-size:12px">${esc(i.satuan)}</span></td>
      <td><span class="pill ${cls(cond)}">${cond}</span></td>
      <td>${esc(i.tahun_pengadaan||'—')}</td>
    </tr>
    <tr class="detail" hidden><td colspan="6"><div class="detail-inner">
      <div class="f"><span>Serial</span>${esc(i.serial||'—')}</div>
      <div class="f"><span>Lokasi</span>${esc(i.lokasi||'—')}</div>
      <div class="f"><span>Penanggung jawab</span>${esc(i.penanggung_jawab||'—')}</div>
      <div class="f"><span>Program</span>${esc(i.program||'—')}</div>
      <div class="f"><span>Pemasok</span>${esc(i.pemasok||'—')}</div>
      <div class="f"><span>Tanggal pembelian</span>${esc(i.tanggal||'—')}</div>
      <div class="f"><span>Garansi</span>${esc(i.garansi||'—')}</div>
      <div class="timeline">${Object.entries(i.kondisi).map(([y,v])=>`<div class="tl"><b>${esc(y)}</b>${v?`<span class="pill ${cls(v.replace(/\s+/g,''))}" style="margin-top:4px">${esc(v)}</span>`:'<span style="color:var(--na);font-size:12px">—</span>'}</div>`).join('')}</div>
    </div></td></tr>`;
  }).join('');
  // expand toggles
  $('#tbody').querySelectorAll('tr.main').forEach(tr=>{
    tr.addEventListener('click',()=>{const d=tr.nextElementSibling;d.hidden=!d.hidden;});
  });
}

function renderSummary(){
  const set=currentSet();
  const t=tally(set);
  const total=set.length||1;
  const bar=COND_ORDER.map(c=>{const n=t[c]||0;if(!n)return'';const pct=(n/total*100).toFixed(2);return `<span style="width:${pct}%;background:${COND_COLOR[c]}" title="${c}: ${n}"></span>`;}).join('');
  const legend=COND_ORDER.map(c=>{const n=t[c]||0;return `<div><i style="background:${COND_COLOR[c]}"></i>${c} <b>${n}</b></div>`;}).join('');
  const title=curLoc==='Semua'?'Seluruh lokasi':curLoc;
  $('#locsummary').innerHTML=`<div class="locsummary">
    <h2>${esc(title)}</h2>
    <div class="sub">${set.length} aset · ${[...new Set(set.map(i=>i.kelompok))].length} kategori</div>
    <div class="condbar">${bar}</div>
    <div class="condlegend">${legend}</div>
  </div>`;
}
</script>
